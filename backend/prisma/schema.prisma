// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model BugReport {
  id           String       @id @default(cuid())
  title        String
  description  String
  cause        String
  solution     String
  snippet      String?
  category     Category     @default(OTHER)
  status       Status       @default(OPEN)
  severity     Severity     @default(MEDIUM)
  isFavorite   Boolean      @default(false)
  resolvedAt   DateTime?
  tags         Tag[]        @relation("BugReportTags")
  technologies Technology[] @relation("BugReportTechnologies")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Tag {
  id         String      @id @default(cuid())
  name       String      @unique
  bugReports BugReport[] @relation("BugReportTags")
}

model Technology {
  id         String      @id @default(cuid())
  name       String      @unique
  bugReports BugReport[] @relation("BugReportTechnologies")
}

enum Status {
  OPEN
  RESOLVED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Category {
  UI
  BACKEND
  DATABASE
  API
  PERFORMANCE
  SECURITY
  OTHER
  FRONTEND
  AUTHENTICATION
  DEPLOYMENT
  DEVOPS
  TESTING
}
